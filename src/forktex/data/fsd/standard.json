  "facets": [

    {"_comment": "═══ Code & Build (service-scoped) ═══"},

    {
      "id": "code-quality",
      "name": "Code Quality",
      "domain": "code",
      "question": "Is the code clean?",
      "atoms": [
        {"ref": "lint", "required": true},
        {"ref": "format", "required": false},
        {"ref": "typecheck", "required": false}
      ]
    },
    {
      "id": "verification",
      "name": "Verification",
      "domain": "code",
      "question": "Is the code correct and safe?",
      "atoms": [
        {"ref": "test", "required": true},
        {"ref": "security-audit", "required": false},
        {"ref": "license", "required": false}
      ]
    },
    {
      "id": "runtime-control",
      "name": "Runtime Control",
      "domain": "infra",
      "question": "Can I start, stop, and inspect the runtime?",
      "atoms": [
        {"ref": "start", "required": true},
        {"ref": "stop", "required": false},
        {"ref": "logs", "required": false},
        {"ref": "db-migrate", "required": false},
        {"ref": "db-reset", "required": false},
        {"ref": "seed", "required": false},
        {"ref": "help", "required": false}
      ]
    },
    {
      "id": "codegen",
      "name": "Code Generation",
      "domain": "code",
      "question": "Are generated artifacts current?",
      "atoms": [
        {"ref": "deps", "required": true},
        {"ref": "codegen", "required": false}
      ]
    },
    {
      "id": "ci-gate",
      "name": "CI Gate",
      "domain": "code",
      "question": "Can this merge?",
      "composesFrom": ["code-quality", "verification"]
    },
    {
      "id": "build-lifecycle",
      "name": "Build Lifecycle",
      "domain": "infra",
      "question": "Can I ship it?",
      "atoms": [
        {"ref": "build", "required": true},
        {"ref": "publish", "required": false},
        {"ref": "clean", "required": false}
      ]
    },

    {"_comment": "═══ Operations (project-scoped) ═══"},

    {
      "id": "deployment",
