{
  "$schema": "https://forktex.com/schemas/fsd/v1/standard.json",
  "version": "1.0.0",

  "domains": [
    {
      "id": "code",
      "name": "Code Quality",
      "description": "Source code correctness, style, type safety, and verification",
      "scope": "service"
    },
    {
      "id": "data",
      "name": "Data",
      "description": "Persistence lifecycle, migrations, reset, and seed flows",
      "scope": "service"
    },
    {
      "id": "infra",
      "name": "Runtime",
      "description": "Runtime control, build surfaces, cleanup, and operator ergonomics",
      "scope": "project"
    },
    {
      "id": "ops",
      "name": "Operations",
      "description": "Deployment, recovery, monitoring, and continuity controls",
      "scope": "project"
    },
    {
      "id": "governance",
      "name": "Governance",
      "description": "Policies, registers, ownership, and organizational structure",
      "scope": "organization"
    },
    {
      "id": "process",
      "name": "Process",
      "description": "Procedures, workflows, and management-system process definitions",
      "scope": "organization"
    },
    {
      "id": "compliance",
      "name": "Compliance",
      "description": "Standards mapping, audit evidence, legal controls, and certification state",
      "scope": "organization"
    },
    {
      "id": "supply-chain",
      "name": "Supply Chain",
      "description": "Third-party providers, supplier assessment, and external obligations",
      "scope": "organization"
    },
    {
      "id": "financial",
      "name": "Financial",
      "description": "Cashflow modeling, pricing, cost management, and revenue tracking",
      "scope": "organization"
    }
  ],

  "resolve_strategies": {
    "make": {
      "description": "Atom satisfied when at least one listed Make target exists in project Makefile(s)",
      "checker": "makefile"
    },
    "path": {
      "description": "Atom satisfied when all listed paths exist (files or directories) relative to docs root",
      "checker": "filesystem"
    },
    "file-content": {
      "description": "Atom satisfied when file exists and contains required content markers",
      "checker": "filesystem"
    },
    "field": {
      "description": "Atom satisfied when a JSON/YAML file contains a non-null value at the given path",
      "checker": "manifest"
    }
  },

  "atoms": [

    {"_comment": "═══════════════════════ DOMAIN: code ═══════════════════════"},

    {
      "id": "format",
      "name": "Format",
      "domain": "code",
      "description": "Source code conforms to a consistent, auto-enforced style",
      "resolve": [
        {"strategy": "make", "any_of": ["format", "format-check"]}
      ],
      "iso": ["9001:8.3.4"],
      "evidence": "Formatter output (zero diff on check)"
    },
    {
      "id": "lint",
      "name": "Lint",
      "domain": "code",
      "description": "Static analysis catches bugs, anti-patterns, and security issues",
      "resolve": [
        {"strategy": "make", "any_of": ["lint", "lint-fix"]}
      ],
      "iso": ["27001:A.8.26", "27001:A.8.28"],
      "evidence": "Linter output (zero errors)"
    },
    {
      "id": "typecheck",
      "name": "Type Check",
      "domain": "code",
      "description": "Static type system verifies interface correctness",
      "resolve": [
        {"strategy": "make", "any_of": ["typecheck"]}
      ],
      "iso": ["27001:A.8.27"],
      "evidence": "Type checker output (zero errors)"
    },
    {
      "id": "test",
      "name": "Test",
      "domain": "code",
      "description": "Automated tests verify behavior against real infrastructure",
      "resolve": [
        {"strategy": "make", "any_of": ["test", "test-cov"]}
      ],
      "iso": ["27001:A.8.29", "9001:8.6", "9001:9.1.1"],
      "evidence": "Test results + coverage report"
    },
    {
      "id": "security-audit",
      "name": "Security Audit",
      "domain": "code",
      "description": "Dependencies scanned for known vulnerabilities",
      "resolve": [
        {"strategy": "make", "any_of": ["audit"]}
      ],
      "iso": ["27001:A.8.8"],
      "evidence": "Dependency vulnerability scan (zero critical/high)"
    },
    {
      "id": "license",
      "name": "License Compliance",
      "domain": "code",
      "description": "Source headers and dependency licenses verified",
      "resolve": [
        {"strategy": "make", "any_of": ["license-check", "license-fix"]}
      ],
      "iso": ["27001:A.5.32"],
      "evidence": "License scan output"
    },
    {
      "id": "deps",
      "name": "Dependencies",
      "domain": "code",
      "description": "Project dependencies installed and locked to reproducible versions",
      "resolve": [
        {"strategy": "make", "any_of": ["deps", "deps-lock"]}
      ],
      "iso": ["27001:A.8.9", "9001:7.1"],
      "evidence": "Lockfile (poetry.lock, pnpm-lock.yaml)"
    },
    {
      "id": "codegen",
      "name": "Code Generation",
      "domain": "code",
      "description": "Typed API clients or other artifacts generated from schemas",
      "resolve": [
        {"strategy": "make", "any_of": ["codegen", "api-client", "openapi", "py-client"]}
      ],
      "iso": ["9001:8.5.1"],
      "evidence": "Generated client matches schema"
    },
    {
      "id": "codegen-check",
      "name": "Codegen Drift Check",
      "domain": "code",
      "description": "Generated artifacts are in sync with their source schemas (CI gate)",
      "resolve": [
        {"strategy": "make", "any_of": ["codegen-check", "sync-check"]}
      ],
      "iso": ["9001:8.5.1", "9001:8.7"],
      "evidence": "CI fails when committed generated files diverge from regeneration"
    },
    {
      "id": "ci",
      "name": "CI Gate",
      "domain": "code",
      "description": "Aggregate quality gate: format + lint + test + audit",
      "resolve": [
        {"strategy": "make", "any_of": ["ci"]}
      ],
      "iso": ["27001:A.8.25", "9001:8.7"],
      "evidence": "CI pipeline pass/fail log"
    },

    {"_comment": "═══════════════════════ DOMAIN: data ═══════════════════════"},

    {
      "id": "db-migrate",
      "name": "DB Migrate",
      "domain": "data",
      "description": "Database schema versioned and migrations applied",
      "resolve": [
        {"strategy": "make", "any_of": ["migrate", "alembic-auto", "alembic-check"]}
      ],
      "iso": ["27001:A.8.32"],
      "evidence": "Alembic version history"
    },
    {
      "id": "db-reset",
      "name": "DB Reset",
      "domain": "data",
      "description": "Database can be dropped and recreated from scratch",
      "resolve": [
        {"strategy": "make", "any_of": ["db-reset"]}
      ],
      "iso": [],
      "evidence": "Clean DB from migrations"
    },
    {
      "id": "seed",
      "name": "Seed",
      "domain": "data",
      "description": "Development data populated for local testing",
      "resolve": [
        {"strategy": "make", "any_of": ["seed", "seed-reset"]}
      ],
      "iso": [],
      "evidence": "Seed script execution"
    },

    {"_comment": "═══════════════════════ DOMAIN: infra ══════════════════════"},

    {
      "id": "start",
      "name": "Start",
      "domain": "infra",
      "description": "Project runtime starts with one command",
      "resolve": [
        {"strategy": "make", "any_of": ["start", "local", "dev"]}
      ],
      "iso": ["9001:7.1.3"],
      "evidence": "Runtime startup output + healthcheck pass"
    },
    {
      "id": "stop",
      "name": "Stop",
      "domain": "infra",
      "description": "Project runtime stops cleanly",
      "resolve": [
        {"strategy": "make", "any_of": ["stop", "local-down", "dev-down"]}
      ],
      "iso": [],
      "evidence": "All runtime processes stopped cleanly"
    },
    {
      "id": "logs",
      "name": "Logs",
      "domain": "infra",
      "description": "Runtime logs observable through one command",
      "resolve": [
        {"strategy": "make", "any_of": ["logs", "local-logs", "dev-logs"]}
      ],
      "iso": [],
      "evidence": "Log stream"
    },
    {
      "id": "build",
      "name": "Build",
      "domain": "infra",
      "description": "Software artifacts built (Docker image, bundle, binary)",
      "resolve": [
        {"strategy": "make", "any_of": ["build"]}
      ],
      "iso": ["9001:8.5.1"],
      "evidence": "Build artifact (image SHA, bundle hash)"
    },
    {
      "id": "publish",
      "name": "Publish",
      "domain": "infra",
      "description": "Artifacts published to registry, CDN, or store",
      "resolve": [
        {"strategy": "make", "any_of": ["publish"]}
      ],
      "iso": ["9001:8.6"],
      "evidence": "Registry record"
    },
    {
      "id": "clean",
      "name": "Clean",
      "domain": "infra",
      "description": "Build artifacts and caches removable",
      "resolve": [
        {"strategy": "make", "any_of": ["clean"]}
      ],
      "iso": [],
      "evidence": "Clean working directory"
    },
    {
      "id": "help",
      "name": "Help",
      "domain": "infra",
      "description": "Available targets self-documented",
      "resolve": [
        {"strategy": "make", "any_of": ["help"]}
      ],
      "iso": [],
      "evidence": "make help output"
    },

    {"_comment": "═══════════════════════ DOMAIN: ops ════════════════════════"},

    {
      "id": "deploy",
      "name": "Deploy",
      "domain": "ops",
      "description": "Services deployed to target environment with zero-downtime strategy",
      "resolve": [
        {"strategy": "make", "any_of": ["deploy", "deploy-staging", "deploy-prod"]},
        {"strategy": "field", "file": "forktex.json", "path": "cloud.deployment.strategy"}
      ],
      "iso": ["27001:A.8.32"],
      "evidence": "Deployment log + health check pass"
    },
    {
      "id": "backup",
      "name": "Backup",
      "domain": "ops",
      "description": "Database and volume backups automated and tested",
      "resolve": [
        {"strategy": "make", "any_of": ["backup", "backup-db"]}
      ],
      "iso": ["27001:A.8.13"],
      "evidence": "Backup execution log + restore test record"
    },
    {
      "id": "rollback",
      "name": "Rollback",
      "domain": "ops",
      "description": "Previous deployment restorable",
      "resolve": [
        {"strategy": "make", "any_of": ["rollback"]}
      ],
      "iso": ["27001:A.8.32"],
      "evidence": "Rollback log"
    },
    {
      "id": "monitoring",
      "name": "Monitoring",
      "domain": "ops",
      "description": "Health checks, metrics, and alerting operational",
      "resolve": [
        {"strategy": "make", "any_of": ["health", "status"]},
        {"strategy": "field", "file": "forktex.json", "path": "cloud.observability.enabled"}
      ],
      "iso": ["27001:A.8.15", "27001:A.8.16"],
      "evidence": "Health endpoint response + dashboard"
    },

    {"_comment": "═══════════════════════ DOMAIN: governance ═════════════════"},

    {
      "id": "org-description",
      "name": "Organization Description",
      "domain": "governance",
      "description": "Company identity, scope, activities, and context documented",
      "resolve": [
        {"strategy": "path", "all_of": ["company/organization/description.md"]}
